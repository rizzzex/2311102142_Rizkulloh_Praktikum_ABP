<%- include('partials/header') %>

<div class="row justify-content-center align-items-center min-vh-75 py-5">
    <div class="col-lg-7 col-md-9">
        <div class="card bg-dark border-secondary shadow-2xl">
            <div class="card-header bg-transparent border-secondary p-4 pt-5 text-center">
                <h2 class="fw-bold mb-2">Input Data <span class="text-gradient">Mahasiswa</span></h2>
                <p class="text-secondary mb-0 opacity-75">Silakan lengkapi formulir di bawah ini dengan benar.</p>
            </div>
            <div class="card-body p-4">
                <form id="studentForm">
                    <div class="mb-3">
                        <label for="nim" class="form-label">NIM</label>
                        <input type="text" class="form-control" id="nim" name="nim" placeholder="Contoh: 211100123" required>
                    </div>
                    <div class="mb-3">
                        <label for="nama" class="form-label">Nama Lengkap</label>
                        <input type="text" class="form-control" id="nama" name="nama" placeholder="Masukan Nama Lengkap" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" placeholder="Contoh: names@email.com" required>
                    </div>
                    <div class="mb-3">
                        <label for="jurusan" class="form-label">Program Studi</label>
                        <select class="form-select" id="jurusan" name="jurusan" required>
                            <option value="">Pilih Program Studi</option>
                            <option value="Informatika">Teknik Informatika</option>
                            <option value="Sistem Informasi">Sistem Informasi</option>
                            <option value="Teknik Industri">Teknik Industri</option>
                            <option value="Arsitektur">Arsitektur</option>
                        </select>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary py-2 rounded-pill fw-bold">
                            <i class="fas fa-save me-2"></i> Simpan Data
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <a href="/table" class="text-secondary text-decoration-none small">
                <i class="fas fa-arrow-left me-1"></i> Kembali ke Daftar
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
